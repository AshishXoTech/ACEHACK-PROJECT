generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums — role is stored as String

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())

  registrations Registration[]
  certificates  Certificate[]
  judge         Judge?
}

model Event {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String
  location             String   @default("")
  startDate            DateTime
  endDate              DateTime
  organizerId          Int
  tracks               String   @default("[]")
  publicUrl            String?
  rulesUrl             String?
  leaderboardPublished Boolean  @default(false)

  teams       Team[]
  certificates Certificate[]
  leaderboardEntries LeaderboardEntry[]
  alerts      Alert[]
}

model Team {
  id      Int    @id @default(autoincrement())
  name    String
  eventId Int
  status  String @default("pending")
  track   String?

  event        Event @relation(fields: [eventId], references: [id])
  registrations Registration[]
  submission    Submission?
  assignments   JudgeAssignment[]
  scores        Score[]
  leaderboardEntries LeaderboardEntry[]
}

model Registration {
  id     Int @id @default(autoincrement())
  teamId Int
  userId Int

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Submission {
  id             Int     @id @default(autoincrement())
  teamId         Int     @unique
  repoLink       String
  profileLink    String

  summary        String?
  techStack      String?
  complexity     String?
  classification String?
  usabilityScore Float?
  commitTotal    Int?
  commitLast7Days Int?
  commitLast30Days Int?
  analyzedAt     DateTime?

  status         String

  team           Team    @relation(fields: [teamId], references: [id])
  scores         Score[]
  leaderboardEntry LeaderboardEntry?
}

model Judge {
  id       Int @id @default(autoincrement())
  userId   Int @unique
  expertise String

  user User @relation(fields: [userId], references: [id])
  assignments JudgeAssignment[]
  scores Score[]
}

model JudgeAssignment {
  id      Int @id @default(autoincrement())
  judgeId Int
  teamId  Int

  judge Judge @relation(fields: [judgeId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])
}

model Score {
  id              Int @id @default(autoincrement())
  judgeId         Int
  submissionId    Int
  teamId          Int
  innovation      Float
  technicalComplexity Float
  design          Float
  impact          Float
  comments        String?
  totalScore      Float
  createdAt       DateTime @default(now())

  judge Judge @relation(fields: [judgeId], references: [id])
  submission Submission @relation(fields: [submissionId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])

  @@unique([judgeId, submissionId])
}

model LeaderboardEntry {
  id           Int      @id @default(autoincrement())
  eventId      Int
  submissionId Int      @unique
  teamId       Int
  totalScore   Float
  rank         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event      Event      @relation(fields: [eventId], references: [id])
  submission Submission @relation(fields: [submissionId], references: [id])
  team       Team       @relation(fields: [teamId], references: [id])

  @@unique([eventId, teamId])
}

model Certificate {
  id             Int @id @default(autoincrement())
  userId         Int
  eventId        Int
  certificateUrl String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

model Sponsor {
  id                  Int      @id @default(autoincrement())
  companyName         String
  industry            String
  website             String
  companyWebsite      String?
  domain              String?
  linkedinCompanyPage String?
  technologies        String
  sponsorshipType     String
  sponsorshipCriteria String
  contactEmail        String
  verificationStatus  String   @default("pending")
  emailVerified       Boolean  @default(false)
  domainVerified      Boolean  @default(false)
  websiteVerified     Boolean  @default(false)
  linkedinVerified    Boolean  @default(false)
  status              String   @default("pending")
  verificationToken   String?
  verificationExpires DateTime?
  createdAt           DateTime @default(now())
}

model VerifiedCompanyDomain {
  id        Int      @id @default(autoincrement())
  domain    String   @unique
  autoApprove Boolean @default(true)
  createdAt DateTime @default(now())
}

model Alert {
  id          String   @id @default(uuid())
  eventId     Int
  title       String
  message     String
  createdBy   Int
  scheduledAt DateTime
  isInstant   Boolean
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@index([scheduledAt])
}
